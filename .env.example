# ==========================================================================
# GymSync — Production Environment Variables
# Copy this to .env on the EC2 server and fill in real values
# ==========================================================================

# Server
NODE_ENV=production
PORT=3001

# JWT Secret — CHANGE THIS in production!
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production

# Database (SQLite for now — path inside container)
DB_PATH=/app/data/gymsync.db

# RDS MySQL (for future migration)
# DB_HOST=gymsync-db.xxxxx.ap-south-1.rds.amazonaws.com
# DB_PORT=3306
# DB_NAME=gymsync
# DB_USER=admin
# DB_PASSWORD=your-rds-password

# Domain (for CORS and Certbot)
# DOMAIN=gymsync.com
# API_URL=https://gymsync.com/api
